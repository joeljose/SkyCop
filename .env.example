# Docker container user — set to match your host UID/GID
# so bind-mounted files are owned by you, not root.
# The Makefile sets these automatically; only override if needed.
CARLA_UID=1000
CARLA_GID=1000

# GPU visibility (default: all GPUs)
NVIDIA_VISIBLE_DEVICES=all

# CARLA server settings
CARLA_PORT=2000
CARLA_STREAMING_PORT=2001
CARLA_TM_PORT=8000

# Quality: Epic (best visuals), Low (fastest, ideal for data collection)
CARLA_QUALITY=Low

# Server tick rate: fixed FPS for reproducible simulation
# Higher = smoother physics but more GPU load
CARLA_FPS=20
